public class ArrayCombinations {
    public static void main(String[] args) {
        int[] arr = {1, 2, 3, 45};

        System.out.println("All unique pairs:");
        for (int i = 0; i < arr.length; i++) {
            for (int j = i + 1; j < arr.length; j++) {
                System.out.println(arr[i] + " " + arr[j]);
            }
        }
    }
}
